# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Claude (briefing + chat)
ANTHROPIC_API_KEY=

# Garmin Railway service (optional in v1 — manual biometrics entry works without it)
GARMIN_SERVICE_URL=https://protocol-garmin.up.railway.app
GARMIN_SERVICE_TOKEN=

# AES-256 key for encrypting stored Garmin passwords (32 random bytes, base64-encoded)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
GARMIN_ENC_KEY=

# Whoop OAuth — register an app at developer.whoop.com to get these
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REDIRECT_URI=

# Optional: still supported from MacroTracker for AI food estimation
GOOGLE_GENERATIVE_AI_API_KEY=

# Bearer token Vercel cron uses to call POST /api/sync/cron and
# POST /api/coach/memory/reindex.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Required in production for the daily 8am UTC sync (see vercel.json).
CRON_SECRET=

# Voyage AI — used by Track 12 (coach long-term memory / RAG) for the
# `voyage-3` embedding model (1024 dims). Anthropic's recommended embedding
# partner; single-vendor with the rest of the AI stack. Embeddings are
# computed nightly by /api/coach/memory/reindex; the chat/briefing routes
# only read. Get a key at https://www.voyageai.com.
VOYAGE_API_KEY=pa-...
